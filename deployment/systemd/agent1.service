[Unit]
Description=Risk Agent 1 (Risk Scoring)
After=network.target redis-server.service

[Service]
User=agent1
Group=agent1
WorkingDirectory=/opt/project/backend
Environment="PYTHONPATH=/opt/project/backend"
ExecStart=/opt/project/backend/agent1_risk/venv/bin/uvicorn agent1_risk.main:app --host 0.0.0.0 --port 8001
Restart=always

[Install]
WantedBy=multi-user.target
